# LLM Provider: "openai" (default) | "claude" | "azure_openai"
LLM_PROVIDER=openai

# OpenAI — use for dev and batch runs
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Claude — use for final demo and serious testing
# Pricing: ~$0.01-0.02 per pipeline run. Total hackathon cost: ~$5-10.
# Get key: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Azure OpenAI — use for production (deployed in your Azure subscription)
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_ENDPOINT=https://starthack-openai.openai.azure.com/
# AZURE_OPENAI_DEPLOYMENT=gpt-4o
# AZURE_OPENAI_API_VERSION=2024-08-01-preview

DATABASE_URL=sqlite:///./auditchain.db
# PostgreSQL for Azure (swap DATABASE_URL after deployment):
# DATABASE_URL=postgresql://auditchain:PASSWORD@starthack-db.postgres.database.azure.com/auditchain

USE_FUZZY=false
ENVIRONMENT=development

# Rate limiting (requests per minute per client IP)
RATE_LIMIT_RPM=60
RATE_LIMIT_ENABLED=true
